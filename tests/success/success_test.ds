// If Statement and Scoping test
let c = 10;

if (1 + 3 - 5 * 2 / 5 % 7) != 2.0 {
    print("yo");
    let c = 20;
    c = 30;
    print(c);
} else if 2 != 2 {
    c = 67;
    print("hi");
} else {
    c = 69;
    print("YO");
}
print(c);

// While test
let i = 0;
while i <= 10 {
    print("yo", i);
    i = i + 1;
}

// Compound Assignment and Increment test
