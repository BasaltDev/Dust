// Gradual Typing test
let a: int = 10;
print(a);
a = 20;
print(a);
let b = 20;
print(b);
//b = "30";
print(b);

// If Statement and Scoping test
let c = 10;

if (1 + 3 - 5 * 2 / 5 % 7) != 2.0 {
    print("yo");
    let c = 20;
    c = 30;
    print(c);
} else if 2 != 2 {
    c = 67;
    print("hi");
} else {
    c = 69;
    print("YO");
}
print(c);

// While test
let i = 0;
while i <= 10 {
    print("yo", i);
    i = i + 1;
}

// Compound Assignment and Increment test
let d = 1;
d += 2;
print(d);
let e = -1;
e -= 1;
print(e);
e++;
e++;
e++;
print(e);
e--;
print(e);

// Type Cast test
let var: string = <string>10;
print(var);
print(<int>var * 2);

// Input test
if input("Yo! ") == "Yo!" {
    print("YO!!!");
} else {
    print("yo...");
}
let f = <int>input("hi, enter a number please: ") + 20;
print(f + 20);

// Function test
func sum(a, b) {
    return a + b;
}
let g = sum(10, 20);
print(g);

// Array & For Loop test
let arr = [10, 20, 30];
print(arr);
func array_mutation(arr: array) {
    let new_arr = arr;
    let sum = 0;
    for i in new_arr {
        sum += i;
    }
    new_arr = push(new_arr, sum);
    return new_arr;
}
arr = push(arr, 10);
print(arr);
arr = remove(arr, 0);
print(arr);
arr = remove(arr, 2);
print(arr);
arr = array_mutation(arr);
print(arr);
print(arr[0]);
arr[0] += 5;
print(arr);
arr[1] = 50;
print(arr);
arr[1] \= 5;
print(arr);
arr = array_mutation(arr);
arr = array_mutation(arr);
arr = array_mutation(arr);
print(arr);
for i in range(0, len(arr)) {
    print(<string>i + ":", arr[i]);
}