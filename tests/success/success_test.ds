print(f + 20);

// Function test
func sum(h, i) {
    return h + i;
}
let g = sum(10, 20);
print(g);

// Array & For Loop test
let arr = [10, 20, 30];
print(arr);
func array_mutation(arr: array) {
    let new_arr = arr;
    let sum = 0;
    for i in new_arr {
        sum += i;
    }
    new_arr = push(new_arr, sum);
    return new_arr;
}
arr = push(arr, 10);
print(arr);
arr = remove(arr, 0);
print(arr);
arr = remove(arr, 2);
print(arr);
arr = array_mutation(arr);
print(arr);
print(arr[0]);
arr[0] += 5;
print(arr);
arr[1] = 50;
print(arr);
arr[1] \= 5;
print(arr);
arr = array_mutation(arr);
arr = array_mutation(arr);
arr = array_mutation(arr);
print(arr);
for i in range(0, len(arr)) {
    print(<string>i + ":", arr[i]);
}

struct Person {
    name: string;
    age: int;
    gender: string;
}

implement for Person {
    func status(self) {
        self.age += 10;
        return "Name: " + self.name + "\nAge: " + <string>self.age + "\nGender: " + self.gender;
    }
}

let person = Person {
    name: "Perr Sonn", /* quite the person indeed */
    age: 463, /* what an age! */
    gender: "gender" /* wow, that's quite a cool gender! */
};

print(person.name, "is", <string>person.age, "years old!");
if person.age > 120 {
    print("Damn,", person.name, "sure is old!");
}
print(person.name, "is of the '" + person.gender + "' gender");
if person.gender != "male" && person.gender != "female" {
    print("Is", person.name, "genderless or something?");
}

print(person.status());
