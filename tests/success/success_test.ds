// Gradual Typing test
let a: int = 10;
print(a);
a = 20;
print(a);
let b = 20;
print(b);
//b = "30";
print(b);

// If Statement and Scoping test
let c = 10;

if (1 + 3 - 5 * 2 / 5 % 7) != 2.0 {
    print("yo");
    let c = 20;
    c = 30;
    print(c);
} else if 2 != 2 {
    c = 67;
    print("hi");
} else {
    c = 69;
    print("YO");
}
print(c);

// While test
let i = 0;
while i <= 10 {
    print("yo", i);
    i = i + 1;
}

// Compound Assignment and Increment test
let d = 1;
d += 2;
print(d);
let e = -1;
e -= 1;
print(e);
e++;
e++;
e++;
print(e);
e--;
print(e);

// Type Cast test
let var: string = <string>10;
print(var);
print(<int>var * 2);

// Input test
if input("Yo! ") == "Yo!" {
    print("YO!!!");
} else {
    print("yo...");
}
let f = <int>input("hi, enter a number please: ") + 20;
print(f + 20);

// Function test
func sum(a, b) {
    return a + b;
}
let g = sum(10, 20);
print(g);